<Application
	x:Class="BazaChecker.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:bazachecker="clr-namespace:BazaChecker">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="/Resources/Lang.ru.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<BooleanToVisibilityConverter
				x:Key="BooleanToVisibilityConverter" />
			<FontFamily
				x:Key="RubikFont">/Assets/Fonts/Rubik/#Rubik</FontFamily>
		</ResourceDictionary>
	</Application.Resources>
</Application>
