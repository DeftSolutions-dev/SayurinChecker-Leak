<Window
	x:Class="BazaChecker.SplashScreen"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Loading..."
	Height="320"
	Width="550"
	WindowStyle="None"
	AllowsTransparency="True"
	Background="#00FFFFFF"
	WindowStartupLocation="CenterScreen"
	ResizeMode="NoResize"
	Topmost="True"
	SnapsToDevicePixels="True"
	UseLayoutRounding="True"
	xmlns:bazachecker="clr-namespace:BazaChecker">
	<Border
		CornerRadius="24"
		BorderThickness="1.5">
		<Border.BorderBrush>
			<LinearGradientBrush
				StartPoint="0,0"
				EndPoint="1,1">
				<GradientStop
					Color="#3A1D54"
					Offset="0" />
				<GradientStop
					Color="#A855F7"
					Offset="0.5" />
				<GradientStop
					Color="#3A1D54"
					Offset="1" />
			</LinearGradientBrush>
		</Border.BorderBrush>
		<Border.Background>
			<RadialGradientBrush
				Center="0.5,0.4"
				GradientOrigin="0.5,0.4"
				RadiusX="0.9"
				RadiusY="0.9">
				<GradientStop
					Color="#12121A"
					Offset="0" />
				<GradientStop
					Color="#050508"
					Offset="1" />
			</RadialGradientBrush>
		</Border.Background>
		<UIElement.Effect>
			<DropShadowEffect
				BlurRadius="40"
				Color="#000000"
				Opacity="0.8"
				ShadowDepth="0" />
		</UIElement.Effect>
		<Grid>
			<Ellipse
				Width="300"
				Height="200"
				Fill="#20A855F7"
				Margin="0,-100,0,0"
				VerticalAlignment="Top">
				<UIElement.Effect>
					<BlurEffect
						Radius="100" />
				</UIElement.Effect>
			</Ellipse>
			<StackPanel
				VerticalAlignment="Center"
				HorizontalAlignment="Center">
				<Grid>
					<TextBlock
						Text="SAYURIN"
						FontSize="62"
						FontWeight="Black"
						HorizontalAlignment="Center"
						Foreground="#40A855F7">
						<UIElement.Effect>
							<BlurEffect
								Radius="15" />
						</UIElement.Effect>
					</TextBlock>
					<TextBlock
						x:Name="TitleText"
						Text="SAYURIN"
						FontSize="62"
						FontWeight="Black"
						HorizontalAlignment="Center">
						<TextBlock.Foreground>
							<LinearGradientBrush
								x:Name="GradientBrush"
								StartPoint="0,0"
								EndPoint="1,1">
								<GradientStop
									x:Name="Stop1"
									Color="#4F46E5"
									Offset="0" />
								<GradientStop
									x:Name="Stop2"
									Color="#9333EA"
									Offset="0.5" />
								<GradientStop
									x:Name="Stop3"
									Color="#DB2777"
									Offset="1" />
							</LinearGradientBrush>
						</TextBlock.Foreground>
					</TextBlock>
				</Grid>
				<TextBlock
					x:Name="TxtStatus"
					Text="Инициализация системы..."
					Foreground="#9CA3AF"
					FontSize="12"
					HorizontalAlignment="Center"
					Margin="0,0,0,12" />
				<Grid
					Width="360">
					<Border
						Background="#1F1F2E"
						CornerRadius="6"
						Height="8" />
					<Border
						x:Name="ProgressGlow"
						CornerRadius="6"
						Height="8"
						HorizontalAlignment="Left"
						Width="0">
						<Border.Background>
							<LinearGradientBrush
								StartPoint="0,0"
								EndPoint="1,0">
								<GradientStop
									Color="#4F46E5"
									Offset="0" />
								<GradientStop
									Color="#9333EA"
									Offset="1" />
							</LinearGradientBrush>
						</Border.Background>
						<UIElement.Effect>
							<DropShadowEffect
								BlurRadius="12"
								Color="#9333EA"
								Opacity="0.6"
								ShadowDepth="0" />
						</UIElement.Effect>
					</Border>
					<Border
						x:Name="ProgressFill"
						CornerRadius="6"
						Height="8"
						HorizontalAlignment="Left"
						Width="0">
						<Border.Background>
							<LinearGradientBrush
								StartPoint="0,0"
								EndPoint="1,0">
								<GradientStop
									Color="#6366F1"
									Offset="0" />
								<GradientStop
									Color="#A855F7"
									Offset="1" />
							</LinearGradientBrush>
						</Border.Background>
					</Border>
				</Grid>
			</StackPanel>
			<StackPanel
				Orientation="Horizontal"
				VerticalAlignment="Bottom"
				HorizontalAlignment="Center"
				Margin="0,0,0,20">
				<TextBlock
					Text="Sayurin Development"
					Foreground="#3F3F46"
					FontSize="10"
					FontWeight="SemiBold" />
				<TextBlock
					Text=" • "
					Foreground="#27272A"
					FontSize="10" />
				<TextBlock
					x:Name="TxtVersion"
					Text="v3.4.9"
					Foreground="#52525B"
					FontSize="10"
					FontWeight="Bold" />
			</StackPanel>
		</Grid>
	</Border>
	<FrameworkElement.Triggers>
		<EventTrigger
			RoutedEvent="Loaded">
			<BeginStoryboard>
				<Storyboard
					RepeatBehavior="Forever">
					<ColorAnimation
						Storyboard.TargetName="Stop1"
						Storyboard.TargetProperty="Color"
						To="#818CF8"
						Duration="0:0:3"
						AutoReverse="True" />
					<ColorAnimation
						Storyboard.TargetName="Stop2"
						Storyboard.TargetProperty="Color"
						To="#C084FC"
						Duration="0:0:3"
						AutoReverse="True" />
					<ColorAnimation
						Storyboard.TargetName="Stop3"
						Storyboard.TargetProperty="Color"
						To="#F472B6"
						Duration="0:0:3"
						AutoReverse="True" />
				</Storyboard>
			</BeginStoryboard>
		</EventTrigger>
	</FrameworkElement.Triggers>
</Window>
