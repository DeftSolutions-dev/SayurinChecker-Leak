<UserControl
	x:Class="BazaChecker.Components.NotificationItemControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
	<Border
		Name="NotifyBorder"
		CornerRadius="14"
		Margin="0,0,0,10"
		Width="300"
		ClipToBounds="True"
		BorderThickness="1"
		Opacity="{Binding OpacityValue}">
		<Border.Background>
			<LinearGradientBrush
				StartPoint="0,0"
				EndPoint="1,1">
				<GradientStop
					Color="#0F0F16"
					Offset="0" />
				<GradientStop
					Color="#0A0A10"
					Offset="1" />
			</LinearGradientBrush>
		</Border.Background>
		<UIElement.Effect>
			<DropShadowEffect
				BlurRadius="20"
				Color="#000000"
				Opacity="0.6"
				ShadowDepth="4"
				Direction="270" />
		</UIElement.Effect>
		<UIElement.RenderTransform>
			<ScaleTransform
				ScaleX="1"
				ScaleY="1" />
		</UIElement.RenderTransform>
		<FrameworkElement.Style>
			<Style
				TargetType="{x:Type Border}">
				<Setter
					Property="UIElement.RenderTransformOrigin"
					Value="1,0.5" />
				<Setter
					Property="BorderBrush"
					Value="#A855F7" />
				<Style.Triggers>
					<DataTrigger
						Value="Error"
						Binding="{Binding Type}">
						<Setter
							Property="BorderBrush"
							Value="#EF4444" />
					</DataTrigger>
					<DataTrigger
						Value="Warning"
						Binding="{Binding Type}">
						<Setter
							Property="BorderBrush"
							Value="#FACC15" />
					</DataTrigger>
					<EventTrigger
						RoutedEvent="Loaded">
						<BeginStoryboard>
							<Storyboard>
								<DoubleAnimation
									Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
									From="0.92"
									To="1"
									Duration="0:0:0.3">
									<DoubleAnimation.EasingFunction>
										<BackEase
											EasingMode="EaseOut"
											Amplitude="0.3" />
									</DoubleAnimation.EasingFunction>
								</DoubleAnimation>
								<DoubleAnimation
									Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
									From="0.92"
									To="1"
									Duration="0:0:0.3">
									<DoubleAnimation.EasingFunction>
										<BackEase
											EasingMode="EaseOut"
											Amplitude="0.3" />
									</DoubleAnimation.EasingFunction>
								</DoubleAnimation>
							</Storyboard>
						</BeginStoryboard>
					</EventTrigger>
				</Style.Triggers>
			</Style>
		</FrameworkElement.Style>
		<Grid>
			<Grid
				Margin="16,10,10,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="Auto" />
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					FontSize="16"
					VerticalAlignment="Center"
					Margin="0,0,10,0"
					Text="{Binding Icon}">
					<FrameworkElement.Style>
						<Style
							TargetType="{x:Type TextBlock}">
							<Setter
								Property="Foreground"
								Value="#A855F7" />
							<Style.Triggers>
								<DataTrigger
									Value="Error"
									Binding="{Binding Type}">
									<Setter
										Property="Foreground"
										Value="#EF4444" />
								</DataTrigger>
								<DataTrigger
									Value="Warning"
									Binding="{Binding Type}">
									<Setter
										Property="Foreground"
										Value="#FACC15" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</FrameworkElement.Style>
				</TextBlock>
				<StackPanel
					Grid.Column="1"
					VerticalAlignment="Center">
					<TextBlock
						FontSize="12"
						FontWeight="SemiBold"
						Foreground="#FFFFFFFF"
						Margin="0,0,0,1"
						Text="{Binding Title}" />
					<TextBlock
						FontSize="10"
						Foreground="#888"
						TextWrapping="Wrap"
						Text="{Binding Message}" />
				</StackPanel>
				<Button
					Grid.Column="2"
					Content="✕"
					Foreground="#444"
					FontSize="10"
					Width="20"
					Height="20"
					Background="#00FFFFFF"
					BorderThickness="0"
					VerticalAlignment="Top"
					Margin="6,-2,-2,0"
					Cursor="Hand"
					Tag="{Binding Id}">
					<FrameworkElement.Style>
						<Style
							TargetType="{x:Type Button}">
							<Setter
								Property="Template">
								<Setter.Value>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="bd"
											Background="#00FFFFFF"
											CornerRadius="10">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="bd"
													Property="Border.Background"
													Value="#20FFFFFF" />
												<Setter
													Property="Foreground"
													Value="#FFFFFFFF" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<DataTrigger
									Value="True"
									Binding="{Binding IsPersistent}">
									<Setter
										Property="Visibility"
										Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</FrameworkElement.Style>
				</Button>
			</Grid>
		</Grid>
	</Border>
</UserControl>
