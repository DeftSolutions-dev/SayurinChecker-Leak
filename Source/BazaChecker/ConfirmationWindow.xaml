<Window
	x:Class="BazaChecker.ConfirmationWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Confirmation"
	Height="180"
	Width="350"
	WindowStyle="None"
	AllowsTransparency="True"
	Background="#00FFFFFF"
	WindowStartupLocation="CenterOwner"
	ShowInTaskbar="False"
	xmlns:bazachecker="clr-namespace:BazaChecker">
	<Border
		CornerRadius="12"
		Background="#0F0F16"
		BorderBrush="#2A2A3A"
		BorderThickness="1">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="*" />
				<RowDefinition
					Height="Auto" />
			</Grid.RowDefinitions>
			<StackPanel
				VerticalAlignment="Center"
				HorizontalAlignment="Center">
				<TextBlock
					x:Name="TxtMessage"
					Text="Закрыть этот процесс?"
					Foreground="#FFFFFFFF"
					FontSize="14"
					FontWeight="SemiBold"
					TextAlignment="Center"
					TextWrapping="Wrap" />
				<TextBlock
					Text="Это действие немедленно завершит работу программы."
					Foreground="#888"
					FontSize="11"
					Margin="0,8,0,0"
					TextAlignment="Center" />
			</StackPanel>
			<UniformGrid
				Grid.Row="1"
				Columns="2"
				Margin="0,15,0,0">
				<Button
					Content="Нет"
					Margin="0,0,5,0"
					Height="34"
					Cursor="Hand"
					Click="No_Click">
					<FrameworkElement.Style>
						<Style
							TargetType="{x:Type Button}">
							<Setter
								Property="Background"
								Value="#1A1A25" />
							<Setter
								Property="Foreground"
								Value="#AAA" />
							<Setter
								Property="Template">
								<Setter.Value>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Background="{TemplateBinding Control.Background}"
											CornerRadius="6"
											BorderBrush="#2A2A38"
											BorderThickness="1">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										Property="Background"
										Value="#252535" />
									<Setter
										Property="Foreground"
										Value="#FFFFFFFF" />
								</Trigger>
							</Style.Triggers>
						</Style>
					</FrameworkElement.Style>
				</Button>
				<Button
					Content="Да"
					Margin="5,0,0,0"
					Height="34"
					Cursor="Hand"
					Click="Yes_Click">
					<FrameworkElement.Style>
						<Style
							TargetType="{x:Type Button}">
							<Setter
								Property="Background"
								Value="#A855F7" />
							<Setter
								Property="Foreground"
								Value="#FFFFFFFF" />
							<Setter
								Property="Template">
								<Setter.Value>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Background="{TemplateBinding Control.Background}"
											CornerRadius="6">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										Property="Background"
										Value="#9333EA" />
								</Trigger>
							</Style.Triggers>
						</Style>
					</FrameworkElement.Style>
				</Button>
			</UniformGrid>
		</Grid>
	</Border>
</Window>
