<Window
	x:Class="BazaChecker.MacroCheckWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Проверка на макросы"
	Height="600"
	Width="650"
	WindowStyle="None"
	AllowsTransparency="True"
	Background="#00FFFFFF"
	WindowStartupLocation="CenterOwner"
	ResizeMode="NoResize"
	xmlns:bazachecker="clr-namespace:BazaChecker">
	<Border
		Background="#0A0A0F"
		CornerRadius="14"
		BorderBrush="#EF4444"
		BorderThickness="2">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition
					Height="50" />
				<RowDefinition
					Height="*" />
				<RowDefinition
					Height="60" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Background="#12121A"
				CornerRadius="14,14,0,0"
				MouseDown="TitleBar_MouseDown">
				<Grid>
					<StackPanel
						Orientation="Horizontal"
						VerticalAlignment="Center"
						Margin="20,0,0,0">
						<TextBlock
							Text="🎯"
							FontSize="18"
							VerticalAlignment="Center"
							Foreground="#FFFFFFFF" />
						<TextBlock
							Text="  Проверка на макросы"
							FontSize="16"
							Foreground="#FFFFFFFF"
							FontWeight="Bold"
							VerticalAlignment="Center" />
					</StackPanel>
					<Button
						Content="✕"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Width="36"
						Height="36"
						Margin="0,0,10,0"
						Background="#00FFFFFF"
						Foreground="#888"
						FontSize="16"
						BorderThickness="0"
						Cursor="Hand"
						Click="Close_Click">
						<FrameworkElement.Style>
							<Style
								TargetType="{x:Type Button}">
								<Setter
									Property="Template">
									<Setter.Value>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												x:Name="bd"
												Background="#00FFFFFF"
												CornerRadius="8">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="bd"
														Property="Border.Background"
														Value="#EF4444" />
													<Setter
														Property="Foreground"
														Value="#FFFFFFFF" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</FrameworkElement.Style>
					</Button>
				</Grid>
			</Border>
			<Border
				Grid.Row="1"
				Background="#12121A"
				Margin="20,10,20,10"
				CornerRadius="8"
				BorderBrush="#1A1A24"
				BorderThickness="1">
				<Canvas
					x:Name="MacroCanvas"
					Background="#00FFFFFF"
					MouseDown="MacroCanvas_MouseDown"
					MouseMove="MacroCanvas_MouseMove"
					MouseUp="MacroCanvas_MouseUp" />
			</Border>
			<Border
				Grid.Row="2"
				Background="#12121A">
				<Grid
					Margin="20,0">
					<StackPanel
						Orientation="Horizontal"
						VerticalAlignment="Center"
						HorizontalAlignment="Left">
						<TextBlock
							Text="Цвет:"
							Foreground="#888"
							FontSize="13"
							VerticalAlignment="Center"
							Margin="0,0,10,0" />
						<Border
							Width="57"
							Height="28"
							Background="#FFFFFFFF"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#FFFFFF"
							BorderBrush="#333"
							BorderThickness="1"
							MouseDown="Color_Click" />
						<Border
							Width="56"
							Height="28"
							Background="#EF4444"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#EF4444"
							MouseDown="Color_Click" />
						<Border
							Width="56"
							Height="28"
							Background="#F59E0B"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#F59E0B"
							MouseDown="Color_Click" />
						<Border
							Width="57"
							Height="28"
							Background="#22C55E"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#22C55E"
							MouseDown="Color_Click" />
						<Border
							Width="56"
							Height="28"
							Background="#06B6D4"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#06B6D4"
							MouseDown="Color_Click" />
						<Border
							Width="56"
							Height="28"
							Background="#3B82F6"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#3B82F6"
							MouseDown="Color_Click" />
						<Border
							Width="56"
							Height="28"
							Background="#A855F7"
							CornerRadius="6"
							Margin="3"
							Cursor="Hand"
							Tag="#A855F7"
							MouseDown="Color_Click" />
					</StackPanel>
					<Button
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Height="36"
						Width="120"
						Click="Clear_Click">
						<FrameworkElement.Style>
							<Style
								TargetType="{x:Type Button}">
								<Setter
									Property="Background"
									Value="#1A1A24" />
								<Setter
									Property="Foreground"
									Value="#FFFFFFFF" />
								<Setter
									Property="BorderThickness"
									Value="0" />
								<Setter
									Property="FrameworkElement.Cursor"
									Value="Hand" />
								<Setter
									Property="Template">
									<Setter.Value>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												x:Name="bd"
												Background="{TemplateBinding Control.Background}"
												CornerRadius="8">
												<StackPanel
													Orientation="Horizontal"
													HorizontalAlignment="Center"
													VerticalAlignment="Center">
													<TextBlock
														Text="🗑️"
														FontSize="14"
														Margin="0,0,8,0"
														Foreground="#FFFFFFFF"
														VerticalAlignment="Center" />
													<TextBlock
														Text="Очистить"
														VerticalAlignment="Center" />
												</StackPanel>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="bd"
														Property="Border.Background"
														Value="#EF4444" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</FrameworkElement.Style>
					</Button>
				</Grid>
			</Border>
			<Grid
				x:Name="PreCheckOverlay"
				RowSpan="4"
				Background="#0A0A0F"
				Visibility="Collapsed"
				ZIndex="100">
				<Border
					Background="#000000"
					Opacity="0.9" />
				<Border
					Background="#12121A"
					Width="500"
					Height="380"
					CornerRadius="16"
					BorderBrush="#EF4444"
					BorderThickness="1">
					<Grid
						Margin="25">
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
							<RowDefinition
								Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock
							Text="Проверка в игре"
							Foreground="#A855F7"
							FontSize="18"
							FontWeight="Bold"
							HorizontalAlignment="Center"
							Margin="0,0,0,20" />
						<StackPanel
							Grid.Row="1">
							<TextBlock
								Text="Требования перед проверкой"
								Foreground="#A855F7"
								FontSize="14"
								FontWeight="Bold"
								Margin="0,0,0,15" />
							<StackPanel
								Orientation="Horizontal"
								Margin="0,0,0,10">
								<TextBlock
									Text="🎮"
									FontSize="20"
									Margin="0,0,10,0"
									Foreground="#FFFFFFFF" />
								<StackPanel>
									<TextBlock
										Text="Режим отображения CS2"
										Foreground="#FFFFFFFF"
										FontWeight="Bold" />
									<TextBlock
										Text="Окно игры должно быть в одном из режимов:"
										Foreground="#888"
										FontSize="11"
										Margin="0,2,0,5" />
									<TextBlock
										Text="✓ Полноэкранный"
										Foreground="#22C55E"
										FontSize="11" />
									<TextBlock
										Text="✓ Полноэкранный в окне"
										Foreground="#22C55E"
										FontSize="11" />
									<TextBlock
										Text="✓ В окне"
										Foreground="#22C55E"
										FontSize="11" />
								</StackPanel>
							</StackPanel>
							<StackPanel
								Orientation="Horizontal"
								Margin="0,15,0,0">
								<TextBlock
									Text="⏸️"
									FontSize="20"
									Margin="0,0,10,0"
									Foreground="#FFFFFFFF" />
								<StackPanel>
									<TextBlock
										Text="После начала проверки"
										Foreground="#FFFFFFFF"
										FontWeight="Bold" />
									<TextBlock
										Text="Когда процесс начнется - пожалуйста, прекратите любые манипуляции:"
										Foreground="#888"
										FontSize="11"
										Margin="0,2,0,5" />
									<TextBlock
										Text="✓ Не трогайте клавиатуру"
										Foreground="#22C55E"
										FontSize="11" />
									<TextBlock
										Text="✓ Не трогайте мышку"
										Foreground="#22C55E"
										FontSize="11" />
									<TextBlock
										Text="✓ Оставайтесь неподвижны до конца"
										Foreground="#22C55E"
										FontSize="11" />
								</StackPanel>
							</StackPanel>
						</StackPanel>
						<StackPanel
							Grid.Row="2"
							Orientation="Horizontal"
							HorizontalAlignment="Center"
							Margin="0,20,0,0">
							<Button
								Content="Отмена"
								Width="100"
								Height="36"
								Margin="0,0,10,0"
								Click="BtnCancelPreCheck_Click">
								<FrameworkElement.Style>
									<Style
										TargetType="{x:Type Button}">
										<Setter
											Property="Background"
											Value="#00FFFFFF" />
										<Setter
											Property="Foreground"
											Value="#888" />
										<Setter
											Property="Template">
											<Setter.Value>
												<ControlTemplate
													TargetType="{x:Type Button}">
													<Border
														x:Name="bd"
														Background="#00FFFFFF"
														CornerRadius="8"
														BorderBrush="#333"
														BorderThickness="1">
														<ContentPresenter
															HorizontalAlignment="Center"
															VerticalAlignment="Center" />
													</Border>
													<ControlTemplate.Triggers>
														<Trigger
															Property="UIElement.IsMouseOver"
															Value="True">
															<Setter
																TargetName="bd"
																Property="Border.BorderBrush"
																Value="#FFFFFFFF" />
															<Setter
																Property="Foreground"
																Value="#FFFFFFFF" />
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
									</Style>
								</FrameworkElement.Style>
							</Button>
							<Button
								x:Name="BtnConfirmStart"
								Width="180"
								Height="36"
								Click="BtnStartBruteForce_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											x:Name="bd"
											Background="#4F46E5"
											CornerRadius="8">
											<StackPanel
												Orientation="Horizontal"
												HorizontalAlignment="Center"
												VerticalAlignment="Center">
												<TextBlock
													Text="🚀"
													FontSize="14"
													Margin="0,0,8,0"
													Foreground="#FFFFFFFF"
													VerticalAlignment="Center" />
												<TextBlock
													Text="Начать проверку"
													Foreground="#FFFFFFFF"
													FontWeight="Bold"
													VerticalAlignment="Center" />
											</StackPanel>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="bd"
													Property="Border.Background"
													Value="#4338CA" />
											</Trigger>
											<Trigger
												Property="UIElement.IsEnabled"
												Value="False">
												<Setter
													TargetName="bd"
													Property="Border.Background"
													Value="#333" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
						</StackPanel>
					</Grid>
				</Border>
			</Grid>
		</Grid>
	</Border>
</Window>
